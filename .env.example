# PoultryMitra Environment Configuration
# Copy this to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poultry_mitra
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (change in production!)
JWT_SECRET=poultry-mitra-secret-change-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# OpenAI API (optional - for advanced AI)
# OPENAI_API_KEY=your-api-key-here